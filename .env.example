# ═══════════════════════════════════════
# Infopet — Variables de entorno
# ═══════════════════════════════════════

# BSALE (ERP/POS)
# Obtener en: app.bsale.cl → Configuraciones → API (o pedir a soporte)
BSALE_TOKEN=

# JUMPSELLER (E-commerce)
# Obtener en: jumpseller.com → panel → Aplicaciones → API Credentials
JUMPSELLER_LOGIN=
JUMPSELLER_AUTH_TOKEN=

# GOOGLE (Service Account para Sheets y Drive)
# Obtener en: console.cloud.google.com → IAM → Service Accounts → Keys
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEETS_ID=
GOOGLE_DRIVE_FOLDER_ID=

# ANTHROPIC (OCR de facturas físicas con Claude Vision)
# Obtener en: console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=

# GMAIL (OAuth2 para notificaciones)
# Obtener en: console.cloud.google.com → APIs → Gmail API → OAuth
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_FROM=infopetrenaca@gmail.com
